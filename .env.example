# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather. The bot must be added as a member to Internal Network Ads.
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram chat ID of the "Internal Network Ads" supergroup (-1001868750472)
TARGET_CHAT_ID=-1001868750472

# ── Railway / Webhook ─────────────────────────────────────────────────────────
# Set this on Railway to enable webhook mode. Leave blank for local polling.
WEBHOOK_URL=https://your-service.up.railway.app
PORT=3000

# ── Google Sheets ─────────────────────────────────────────────────────────────
# A/B TEST SETUP:
#   BOT TARGET  → "AI TEST - [Master] Revenue Sheet" (bot writes here during trial)
#   ORIGINAL    → https://docs.google.com/spreadsheets/d/1R-UV1B1TWrFVxzFNEbUKeoGubHrZ0Tg-HIdYYuOvY7s (manual process continues here)
#
# Once validated, swap MASTER_SHEET_ID to the original sheet ID to go live.
MASTER_SHEET_ID=1T6bK0ko8M8wQkSYaILTMpGdycAGKXKY4C1Tgyx5csY0

# Name of the tab to append rows to (default: "IG Revenue Tracker")
SHEET_TAB_NAME=IG Revenue Tracker

# Google Service Account credentials (paste full JSON as a single line, or use the file path below)
# Option A — inline JSON string (recommended for Railway env vars):
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B — path to credentials file (for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json
